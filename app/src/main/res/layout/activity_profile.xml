<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- Sticky Bottom Nav -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:background="@color/background"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:paddingTop="8dp">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⌂" android:textSize="22sp" android:textColor="@color/text_sub" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textSize="10sp" android:textColor="@color/text_sub" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navMap"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="◎" android:textSize="22sp" android:textColor="@color/text_sub" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Map" android:textSize="10sp" android:textColor="@color/text_sub" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navBrowse"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="≡" android:textSize="22sp" android:textColor="@color/text_sub" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Browse" android:textSize="10sp" android:textColor="@color/text_sub" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navChat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✉" android:textSize="22sp" android:textColor="@color/text_sub" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chat" android:textSize="10sp" android:textColor="@color/text_sub" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="◉" android:textSize="22sp" android:textColor="@color/primary" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profile" android:textSize="10sp" android:textColor="@color/primary" />
        </LinearLayout>

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_above="@id/bottomNav" android:background="@color/border" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNav"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Toolbar-like header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:id="@+id/ivBack"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_menu_revert"
                    android:contentDescription="Back"
                    app:tint="@color/text_main" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="05 · profile"
                    android:textColor="@color/text_sub"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="•••"
                    android:textColor="@color/text_main"
                    android:textSize="18sp" />
            </RelativeLayout>

            <!-- User Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="24dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvAvatar"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_avatar"
                    android:gravity="center"
                    android:text="MR"
                    android:textColor="#3D4E27"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="20dp">

                    <TextView
                        android:id="@+id/tvUsername"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="marcus_r"
                        android:textColor="@color/text_main"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvBio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DIY homeowner · Cebu, PH"
                        android:textColor="@color/text_sub"
                        android:textSize="14sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                android:paddingBottom="24dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tvRating" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4.8" android:textColor="@color/primary" android:textSize="22sp" android:fontFamily="sans-serif-medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rating" android:textColor="@color/text_sub" android:textSize="11sp" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="30dp" android:background="@color/border" android:layout_gravity="center_vertical" />

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tvLends" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12" android:textColor="@color/primary" android:textSize="22sp" android:fontFamily="sans-serif-medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lends" android:textColor="@color/text_sub" android:textSize="11sp" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="30dp" android:background="@color/border" android:layout_gravity="center_vertical" />

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tvBorrows" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="7" android:textColor="@color/primary" android:textSize="22sp" android:fontFamily="sans-serif-medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Borrows" android:textColor="@color/text_sub" android:textSize="11sp" />
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="30dp" android:background="@color/border" android:layout_gravity="center_vertical" />

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/tvListed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5" android:textColor="@color/primary" android:textSize="22sp" android:fontFamily="sans-serif-medium" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Listed" android:textColor="@color/text_sub" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Tabs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <LinearLayout
                    android:id="@+id/tabMyTools"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="My tools" android:textColor="@color/primary" android:textSize="14sp" android:fontFamily="sans-serif-medium" android:paddingVertical="12dp" />
                    <View android:id="@+id/tabMyToolsIndicator" android:layout_width="match_parent" android:layout_height="2dp" android:background="@color/primary" android:layout_marginHorizontal="12dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tabHistory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="History" android:textColor="@color/text_sub" android:textSize="14sp" android:paddingVertical="12dp" />
                    <View android:id="@+id/tabHistoryIndicator" android:layout_width="match_parent" android:layout_height="2dp" android:background="@color/border" android:layout_marginHorizontal="12dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tabReviews"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reviews" android:textColor="@color/text_sub" android:textSize="14sp" android:paddingVertical="12dp" />
                    <View android:id="@+id/tabReviewsIndicator" android:layout_width="match_parent" android:layout_height="2dp" android:background="@color/border" android:layout_marginHorizontal="12dp" />
                </LinearLayout>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border" />

            <!-- Lists -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <ListView
                    android:id="@+id/listViewMyTools"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:divider="@null"
                    android:dividerHeight="0dp"
                    android:nestedScrollingEnabled="false" />

                <ListView
                    android:id="@+id/listViewHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:divider="@null"
                    android:dividerHeight="0dp"
                    android:visibility="gone"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    android:id="@+id/tvHistoryEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingTop="32dp"
                    android:text="No tools found"
                    android:textColor="@color/text_sub"
                    android:visibility="gone" />

            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingBottom="24dp">

                <Button
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="Log out"
                    android:textAllCaps="false"
                    android:textColor="#FF6B6B"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_outline_btn_red" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</RelativeLayout>
