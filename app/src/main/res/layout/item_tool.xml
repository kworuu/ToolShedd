<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:padding="20dp"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:id="@+id/llToolInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_centerVertical="true">

        <TextView
            android:id="@+id/tvItemToolName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tool name"
            android:textColor="@color/text_main"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvItemToolBrand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Brand · Model"
            android:textColor="@color/text_sub"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvItemToolStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:background="@drawable/bg_badge_green"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:text="Available"
        android:textColor="#3D4E27"
        android:textSize="12sp"
        android:textStyle="bold" />

</RelativeLayout>
